<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Prévisualisation — {{ history.title }} (v{{ history.version }})</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <style>
        :root {
            --preview-primary: {{ history.colorPrimary ?: '#0d6efd' }};
            --preview-secondary: {{ history.colorSecondary ?: '#6c757d' }};
        }
        body { background: #f8f9fa; }
        .preview-banner {
            background: #212529;
            color: #fff;
            padding: .5rem 1rem;
            font-size: .85rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
        }
        .preview-banner .badge-version {
            background: var(--preview-primary);
            color: #fff;
            padding: .25rem .6rem;
            border-radius: .375rem;
            font-weight: 600;
        }
        .hero-preview {
            background: var(--preview-primary);
            color: #fff;
            padding: 2.5rem 2rem;
            border-radius: .5rem;
        }
        .swatch {
            display: inline-block;
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 2px solid #dee2e6;
            vertical-align: middle;
        }
        .content-html { line-height: 1.75; }
    </style>
</head>
<body>

{# Bandeau d'information sur la version #}
<div class="preview-banner">
    <span>🔍 Prévisualisation</span>
    <span class="badge-version">v{{ history.version }}</span>
    <span>{{ history.createdAt|date('d/m/Y à H:i') }}</span>
    <span>par <strong>{{ history.createdBy }}</strong></span>
    <span class="ms-auto">
        {% if history.revisionStatus == 1 or history.revisionStatus == 3 %}
            <span class="badge bg-success">Approuvée</span>
        {% elseif history.revisionStatus == 0 %}
            <span class="badge bg-warning text-dark">En attente</span>
        {% else %}
            <span class="badge bg-danger">Rejetée</span>
        {% endif %}
    </span>
    <button onclick="window.close()" class="btn btn-sm btn-outline-light">Fermer</button>
</div>

<div class="container py-4">

    {# Hero : titre + couleur primaire #}
    <div class="hero-preview mb-4">
        <div class="d-flex align-items-center gap-4 flex-wrap">
            {% if history.logo %}
                <img src="/uploads/formation-logos/{{ history.logo }}"
                     alt="Logo {{ history.title }}"
                     style="max-height: 90px; max-width: 180px; object-fit: contain; background: #fff; border-radius: .375rem; padding: .25rem;">
            {% endif %}
            <div>
                <h1 class="h2 mb-1">{{ history.title }}</h1>
                <code class="text-white-50">{{ history.slug }}</code>
            </div>
        </div>
    </div>

    <div class="row g-4">

        {# Colonne principale #}
        <div class="col-lg-8">

            {% if history.descriptionCourte %}
                <div class="card mb-3 border-0 shadow-sm">
                    <div class="card-header fw-semibold bg-light">Description courte</div>
                    <div class="card-body text-muted">{{ history.descriptionCourte }}</div>
                </div>
            {% endif %}

            {% if history.description %}
                <div class="card border-0 shadow-sm">
                    <div class="card-header fw-semibold bg-light">Description complète</div>
                    <div class="card-body content-html">
                        {{ history.description|raw }}
                    </div>
                </div>
            {% else %}
                <div class="alert alert-secondary">Aucune description.</div>
            {% endif %}

        </div>

        {# Colonne latérale #}
        <div class="col-lg-4">

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header fw-semibold bg-light">Informations</div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Statut</span>
                        <span class="badge
                            {% if history.status == 'published' %}bg-success
                            {% elseif history.status == 'recruiting' %}bg-primary
                            {% elseif history.status == 'archived' %}bg-secondary
                            {% else %}bg-warning text-dark{% endif %}">
                            {{ history.status }}
                        </span>
                    </li>
                    {% if history.publishedAt %}
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-muted">Publication</span>
                        <strong>{{ history.publishedAt|date('d/m/Y') }}</strong>
                    </li>
                    {% endif %}
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="text-muted">Couleur primaire</span>
                        <span>
                            {% if history.colorPrimary %}
                                <span class="swatch me-1" style="background: {{ history.colorPrimary }};"></span>
                                <code>{{ history.colorPrimary }}</code>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="text-muted">Couleur secondaire</span>
                        <span>
                            {% if history.colorSecondary %}
                                <span class="swatch me-1" style="background: {{ history.colorSecondary }};"></span>
                                <code>{{ history.colorSecondary }}</code>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </span>
                    </li>
                </ul>
            </div>

            {% if history.responsables is not empty %}
                <div class="card border-0 shadow-sm">
                    <div class="card-header fw-semibold bg-light">Responsables</div>
                    <ul class="list-group list-group-flush">
                        {% for user in history.responsables %}
                            <li class="list-group-item">{{ user }}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}

        </div>
    </div>

    {# Note de révision #}
    {% if history.reviewNote %}
        <div class="alert mt-4
            {% if history.revisionStatus == 2 %}alert-danger{% else %}alert-info{% endif %}">
            <strong>Note du réviseur :</strong> {{ history.reviewNote }}
        </div>
    {% endif %}

</div>
</body>
</html>
