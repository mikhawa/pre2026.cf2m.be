<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Prévisualisation — {{ history.title }} (v{{ history.version }})</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <style>
        body { background: #f8f9fa; }
        .preview-banner {
            background: #212529;
            color: #fff;
            padding: .5rem 1rem;
            font-size: .85rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
        }
        .preview-banner .badge-version {
            background: #0d6efd;
            color: #fff;
            padding: .25rem .6rem;
            border-radius: .375rem;
            font-weight: 600;
        }
        .content-html { line-height: 1.8; }
    </style>
</head>
<body>

{# Bandeau d'information sur la version #}
<div class="preview-banner">
    <span>🔍 Prévisualisation</span>
    <span class="badge-version">v{{ history.version }}</span>
    <span>{{ history.createdAt|date('d/m/Y à H:i') }}</span>
    <span>par <strong>{{ history.createdBy }}</strong></span>
    <span class="ms-auto">
        {% if history.revisionStatus == 1 or history.revisionStatus == 3 %}
            <span class="badge bg-success">Approuvée</span>
        {% elseif history.revisionStatus == 0 %}
            <span class="badge bg-warning text-dark">En attente</span>
        {% else %}
            <span class="badge bg-danger">Rejetée</span>
        {% endif %}
    </span>
    <button onclick="window.close()" class="btn btn-sm btn-outline-light">Fermer</button>
</div>

<div class="container py-4">

    {# En-tête du work #}
    <div class="mb-4">
        <h1 class="h2">{{ history.title }}</h1>
        <div class="d-flex gap-3 flex-wrap align-items-center text-muted small">
            <code>{{ history.slug }}</code>
            <span class="badge
                {% if history.status == 'published' %}bg-success
                {% elseif history.status == 'archived' %}bg-secondary
                {% else %}bg-warning text-dark{% endif %}">
                {{ history.status }}
            </span>
            {% if history.publishedAt %}
                <span>Publié le {{ history.publishedAt|date('d/m/Y') }}</span>
            {% endif %}
        </div>
    </div>

    <div class="row g-4">

        {# Contenu HTML #}
        <div class="col-lg-8">
            {% if history.description %}
                <div class="card border-0 shadow-sm">
                    <div class="card-header fw-semibold bg-light">Description</div>
                    <div class="card-body content-html">
                        {{ history.description|raw }}
                    </div>
                </div>
            {% else %}
                <div class="alert alert-secondary">Aucune description.</div>
            {% endif %}
        </div>

        {# Informations latérales #}
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-header fw-semibold bg-light">Formation parente</div>
                <div class="card-body">
                    {% if history.formation %}
                        <strong>{{ history.formation.title }}</strong>
                        {% if history.formation.colorPrimary %}
                            <span class="d-inline-block rounded-circle border ms-2"
                                  style="width:16px;height:16px;background:{{ history.formation.colorPrimary }};vertical-align:middle;"></span>
                        {% endif %}
                    {% else %}
                        <span class="text-muted">—</span>
                    {% endif %}
                </div>
            </div>

            {% if history.users is not empty %}
                <div class="card border-0 shadow-sm">
                    <div class="card-header fw-semibold bg-light">Auteur(s)</div>
                    <ul class="list-group list-group-flush">
                        {% for user in history.users %}
                            <li class="list-group-item">{{ user }}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}
        </div>
    </div>

    {# Note de révision #}
    {% if history.reviewNote %}
        <div class="alert mt-4
            {% if history.revisionStatus == 2 %}alert-danger{% else %}alert-info{% endif %}">
            <strong>Note du réviseur :</strong> {{ history.reviewNote }}
        </div>
    {% endif %}

</div>
</body>
</html>
