<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}CF2m — Centre de Formation{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><rect width=%22128%22 height=%22128%22 rx=%2216%22 fill=%22%231a2e4a%22/><text y=%221em%22 x=%2264%22 text-anchor=%22middle%22 font-size=%2256%22 font-family=%22sans-serif%22 fill=%22%23e85d04%22 font-weight=%22bold%22>CF</text></svg>">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body class="{% block body_class %}{% endblock %}"
          data-page="{{ app.request.pathInfo == '/' ? 'home' : 'inner' }}">

        {# ── Navigation ──────────────────────────────────────────────── #}
        {%- set _nav_formations = nav_formations() -%}
        {%- set _nav_pages = nav_pages() -%}
        <header>
            <nav class="navbar navbar-expand-lg navbar-dark cf2m-navbar"
                 aria-label="Navigation principale">
                <div class="container">

                    {# Logo seul (icône circulaire) #}
                    <a class="navbar-brand" href="{{ path('app_home') }}" aria-label="CF2m — Accueil">
                        <img src="{{ asset('images/logo-cf2m-blanc.svg') }}"
                             alt="Logo CF2m"
                             width="80" height="80"
                             class="cf2m-logo-img">
                    </a>

                    {# Toggler mobile #}
                    <button class="navbar-toggler border-0" type="button"
                            data-bs-toggle="collapse" data-bs-target="#navbarMain"
                            aria-controls="navbarMain" aria-expanded="false"
                            aria-label="Afficher/masquer le menu">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    {# Liens centrés + auth à droite #}
                    <div class="collapse navbar-collapse" id="navbarMain">

                        {# Liens principaux — centrés via mx-auto #}
                        <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-lg-1">

                            <li class="nav-item">
                                <a class="nav-link {% if app.request.pathInfo == '/' %}active{% endif %}"
                                   href="{{ path('app_home') }}">Accueil</a>
                            </li>

                            {# Dropdown Nos formations #}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#"
                                   id="dropdownFormations" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    Nos formations
                                </a>
                                <ul class="dropdown-menu cf2m-dropdown" aria-labelledby="dropdownFormations">
                                    {% if _nav_formations is empty %}
                                        <li>
                                            <span class="dropdown-item-text text-muted fst-italic">
                                                Aucune formation disponible
                                            </span>
                                        </li>
                                    {% else %}
                                        {% for formation in _nav_formations %}
                                            <li>
                                                <a class="dropdown-item cf2m-dropdown-item"
                                                   href="{{ path('app_formation_show', {slug: formation.slug}) }}">
                                                    <span class="cf2m-dropdown-arrow">›</span>
                                                    {{ formation.title }}
                                                </a>
                                            </li>
                                        {% endfor %}
                                        <li><hr class="dropdown-divider cf2m-dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item cf2m-dropdown-all"
                                               href="{{ path('app_home') }}#formations">
                                                Voir toutes les formations →
                                            </a>
                                        </li>
                                    {% endif %}
                                </ul>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_contact' %}active{% endif %}"
                                   href="{{ path('app_contact') }}">Nous contacter</a>
                            </li>

                            {# Dropdown Nos activités #}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#"
                                   id="dropdownActivites" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    Nos activités
                                </a>
                                <ul class="dropdown-menu cf2m-dropdown" aria-labelledby="dropdownActivites">
                                    {% if _nav_pages is empty %}
                                        <li>
                                            <span class="dropdown-item-text text-muted fst-italic">
                                                Aucune activité disponible
                                            </span>
                                        </li>
                                    {% else %}
                                        {% for page in _nav_pages %}
                                            <li>
                                                <a class="dropdown-item cf2m-dropdown-item"
                                                   href="{{ path('app_page_show', {slug: page.slug}) }}">
                                                    <span class="cf2m-dropdown-arrow">›</span>
                                                    {{ page.title }}
                                                </a>
                                            </li>
                                        {% endfor %}
                                    {% endif %}
                                </ul>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link cf2m-nav-external"
                                   href="https://cf2d.be/"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   title="Visiter le site CF2d (nouvel onglet)">
                                    CF2d
                                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11"
                                         viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                         stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                                         aria-hidden="true" class="cf2m-external-icon">
                                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                                        <polyline points="15 3 21 3 21 9"/>
                                        <line x1="10" y1="14" x2="21" y2="3"/>
                                    </svg>
                                </a>
                            </li>
                        </ul>

                        {# Auth — droite #}
                        <div class="d-flex align-items-center gap-3">
                            {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                                <div class="dropdown">
                                    <button class="cf2m-user-dropdown-toggle dropdown-toggle"
                                            type="button"
                                            id="dropdownUser"
                                            data-bs-toggle="dropdown"
                                            aria-expanded="false">
                                        <span class="cf2m-user-avatar-icon" aria-hidden="true">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                 viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <circle cx="12" cy="8" r="4"/>
                                                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                                            </svg>
                                        </span>
                                        {{ app.user.userName ?? app.user.email }}
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end cf2m-dropdown cf2m-user-dropdown"
                                        aria-labelledby="dropdownUser">
                                        <li>
                                            <a class="dropdown-item cf2m-dropdown-item"
                                               href="{{ path('app_profile') }}">
                                                <span class="cf2m-dropdown-arrow">›</span>
                                                Mon profil
                                            </a>
                                        </li>
                                        {% if is_granted('ROLE_ADMIN') %}
                                            <li>
                                                <a class="dropdown-item cf2m-dropdown-item"
                                                   href="/admin">
                                                    <span class="cf2m-dropdown-arrow">›</span>
                                                    Administration
                                                </a>
                                            </li>
                                        {% endif %}
                                        <li><hr class="dropdown-divider cf2m-dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item cf2m-dropdown-all"
                                               href="{{ path('app_logout') }}">
                                                Déconnexion
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            {% else %}
                                <a class="cf2m-btn-connexion" href="{{ path('app_login') }}">
                                    Connexion
                                </a>
                            {% endif %}
                        </div>

                    </div>
                </div>
            </nav>
        </header>

        {# ── Contenu principal ───────────────────────────────────────── #}
        <main>
            {% block body %}{% endblock %}
        </main>

        {# ── Pied de page ────────────────────────────────────────────── #}
        <footer class="cf2m-footer py-4">
            <div class="container">
                <div class="row align-items-center">

                    {# Colonne gauche : logo + texte #}
                    <div class="col-md-4 text-center text-md-start mb-3 mb-md-0 d-flex align-items-center justify-content-center justify-content-md-start gap-2">
                        <a href="{{ path('app_home') }}" aria-label="CF2m — Accueil">
                            <img src="{{ asset('images/logo-cf2m-blanc.svg') }}"
                                 alt="Logo CF2m"
                                 width="50" height="50"
                                 class="cf2m-logo-img">
                        </a>
                        <span class="text-muted">Centre de Formation</span>
                    </div>

                    {# Colonne centre : Nos activités #}
                    <div class="col-md-4 text-center mb-3 mb-md-0">
                        {% if _nav_pages is not empty %}
                            <p class="text-muted small fw-semibold mb-1 text-uppercase">Nos activités</p>
                            <ul class="list-unstyled mb-0">
                                {% for page in _nav_pages %}
                                    <li>
                                        <a class="text-muted text-decoration-none cf2m-footer-link small"
                                           href="{{ path('app_page_show', {slug: page.slug}) }}">
                                            {{ page.title }}
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% endif %}
                    </div>

                    {# Colonne droite : copyright #}
                    <div class="col-md-4 text-center text-md-end">
                        <small class="text-muted">&copy; {{ 'now'|date('Y') }} CF2m — Tous droits réservés</small>
                    </div>

                </div>
            </div>
        </footer>

    </body>
</html>
