<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}CF2m — Centre de Formation{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><rect width=%22128%22 height=%22128%22 rx=%2216%22 fill=%22%231a2e4a%22/><text y=%221em%22 x=%2264%22 text-anchor=%22middle%22 font-size=%2256%22 font-family=%22sans-serif%22 fill=%22%23e85d04%22 font-weight=%22bold%22>CF</text></svg>">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>

        {# ── Navigation ──────────────────────────────────────────────── #}
        <header>
            <nav class="navbar navbar-expand-lg navbar-dark cf2m-navbar sticky-top" aria-label="Navigation principale">
                <div class="container">
                    {# Logo / Marque #}
                    <a class="navbar-brand fw-bold fs-4" href="{{ path('app_home') }}">
                        <span class="cf2m-brand-cf">CF</span><span class="cf2m-brand-2m">2m</span>
                    </a>

                    {# Toggler mobile #}
                    <button class="navbar-toggler" type="button"
                            data-bs-toggle="collapse" data-bs-target="#navbarMain"
                            aria-controls="navbarMain" aria-expanded="false"
                            aria-label="Afficher/masquer le menu">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    {# Liens #}
                    <div class="collapse navbar-collapse" id="navbarMain">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.pathInfo == '/' %}active{% endif %}"
                                   href="{{ path('app_home') }}">Accueil</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_home') }}#formations">Formations</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">À propos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">Contact</a>
                            </li>
                        </ul>

                        {# Auth #}
                        <div class="d-flex align-items-center gap-2">
                            {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                                <a class="nav-link text-white" href="#">
                                    <i class="bi bi-person-circle me-1"></i>
                                    {{ app.user.userName ?? app.user.email }}
                                </a>
                                <a class="btn btn-outline-light btn-sm" href="#">Déconnexion</a>
                            {% else %}
                                <a class="btn cf2m-btn-accent btn-sm" href="#">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Se connecter
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </nav>
        </header>

        {# ── Contenu principal ───────────────────────────────────────── #}
        <main>
            {% block body %}{% endblock %}
        </main>

        {# ── Pied de page ────────────────────────────────────────────── #}
        <footer class="cf2m-footer py-4 mt-5">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-6 text-center text-md-start mb-2 mb-md-0">
                        <span class="fw-bold cf2m-brand-cf">CF</span><span class="fw-bold cf2m-brand-2m">2m</span>
                        <span class="text-muted ms-2">Centre de Formation</span>
                    </div>
                    <div class="col-md-6 text-center text-md-end">
                        <small class="text-muted">&copy; {{ 'now'|date('Y') }} CF2m — Tous droits réservés</small>
                    </div>
                </div>
            </div>
        </footer>

    </body>
</html>
