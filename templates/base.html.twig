<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}CF2m — Centre de Formation{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><rect width=%22128%22 height=%22128%22 rx=%2216%22 fill=%22%231a2e4a%22/><text y=%221em%22 x=%2264%22 text-anchor=%22middle%22 font-size=%2256%22 font-family=%22sans-serif%22 fill=%22%23e85d04%22 font-weight=%22bold%22>CF</text></svg>">
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>

        {# ── Navigation ──────────────────────────────────────────────── #}
        {%- set _nav_formations = nav_formations() -%}
        <header>
            <nav class="navbar navbar-expand-lg navbar-dark cf2m-navbar sticky-top" aria-label="Navigation principale">
                <div class="container">

                    {# Logo / Marque #}
                    <a class="navbar-brand fw-bold fs-4" href="{{ path('app_home') }}">
                        <span class="cf2m-brand-cf">CF</span><span class="cf2m-brand-2m">2m</span>
                    </a>

                    {# Toggler mobile #}
                    <button class="navbar-toggler" type="button"
                            data-bs-toggle="collapse" data-bs-target="#navbarMain"
                            aria-controls="navbarMain" aria-expanded="false"
                            aria-label="Afficher/masquer le menu">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    {# Liens #}
                    <div class="collapse navbar-collapse" id="navbarMain">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                            <li class="nav-item">
                                <a class="nav-link {% if app.request.pathInfo == '/' %}active{% endif %}"
                                   href="{{ path('app_home') }}">Accueil</a>
                            </li>

                            {# Dropdown Formations #}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#"
                                   id="dropdownFormations" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    Formations
                                    {% if _nav_formations|length > 0 %}
                                        <span class="cf2m-nav-count">{{ _nav_formations|length }}</span>
                                    {% endif %}
                                </a>
                                <ul class="dropdown-menu cf2m-dropdown" aria-labelledby="dropdownFormations">
                                    {% if _nav_formations is empty %}
                                        <li>
                                            <span class="dropdown-item-text text-muted fst-italic">
                                                Aucune formation disponible
                                            </span>
                                        </li>
                                    {% else %}
                                        {% for formation in _nav_formations %}
                                            <li>
                                                <a class="dropdown-item cf2m-dropdown-item" href="#">
                                                    <span class="cf2m-dropdown-arrow">›</span>
                                                    {{ formation.title }}
                                                </a>
                                            </li>
                                        {% endfor %}
                                        <li><hr class="dropdown-divider cf2m-dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item cf2m-dropdown-all" href="{{ path('app_home') }}#formations">
                                                Voir toutes les formations →
                                            </a>
                                        </li>
                                    {% endif %}
                                </ul>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="#">À propos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">Contact</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link cf2m-nav-external"
                                   href="https://cf2d.be/"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   title="Visiter le site CF2d (nouvel onglet)">
                                    CF2d
                                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="cf2m-external-icon"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                                </a>
                            </li>
                        </ul>

                        {# Auth #}
                        <div class="d-flex align-items-center gap-2 ms-lg-3">
                            {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                                <a class="nav-link text-white" href="#">
                                    {{ app.user.userName ?? app.user.email }}
                                </a>
                                <a class="btn btn-outline-light btn-sm" href="#">Déconnexion</a>
                            {% else %}
                                <a class="cf2m-btn-connexion" href="#">
                                    Connexion
                                </a>
                            {% endif %}
                        </div>
                    </div>

                </div>
            </nav>
        </header>

        {# ── Contenu principal ───────────────────────────────────────── #}
        <main>
            {% block body %}{% endblock %}
        </main>

        {# ── Pied de page ────────────────────────────────────────────── #}
        <footer class="cf2m-footer py-4 mt-5">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-6 text-center text-md-start mb-2 mb-md-0">
                        <span class="fw-bold cf2m-brand-cf">CF</span><span class="fw-bold cf2m-brand-2m">2m</span>
                        <span class="text-muted ms-2">Centre de Formation</span>
                    </div>
                    <div class="col-md-6 text-center text-md-end">
                        <small class="text-muted">&copy; {{ 'now'|date('Y') }} CF2m — Tous droits réservés</small>
                    </div>
                </div>
            </div>
        </footer>

    </body>
</html>
