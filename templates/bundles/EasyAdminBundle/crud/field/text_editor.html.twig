{# @var ea \EasyCorp\Bundle\EasyAdminBundle\Context\AdminContext #}
{# @var field \EasyCorp\Bundle\EasyAdminBundle\Dto\FieldDto #}
{# @var entity \EasyCorp\Bundle\EasyAdminBundle\Dto\EntityDto #}
{% set content = field.formattedValue %}

{% if ea().crud.currentAction == 'index' %}
    {# Vue liste : texte tronqué, sans HTML #}
    {% if content %}
        <span class="text-muted small">{{ content|striptags|slice(0, 120) }}{% if content|striptags|length > 120 %}…{% endif %}</span>
    {% else %}
        <span class="text-muted">—</span>
    {% endif %}

{% else %}
    {# Vue détail : affichage HTML complet #}
    {% set html_id = 'suneditor-detail-' ~ field.uniqueId %}
    <a href="#" data-bs-toggle="modal" data-bs-target="#{{ html_id }}" class="btn btn-sm btn-outline-secondary">
        <i class="fa fa-eye me-1"></i> Voir le contenu
    </a>

    <div class="modal fade" id="{{ html_id }}" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-xl" role="document">
            <div class="modal-content">
                <div class="modal-header d-flex justify-content-between">
                    <h5 class="modal-title">{{ field.label|trans }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>
                <div class="modal-body">
                    {% if content %}
                        <div class="suneditor-content p-3">{{ content|raw }}</div>
                    {% else %}
                        <p class="text-muted">Aucun contenu.</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endif %}
