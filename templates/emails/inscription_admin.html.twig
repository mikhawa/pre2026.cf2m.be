<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" lang="fr">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nouvelle préinscription — CF2m</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f0f6fa;">

    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f0f6fa;">
        <tr>
            <td align="center" style="padding: 32px 16px;">

                <table width="600" cellpadding="0" cellspacing="0" border="0"
                       style="background-color: #ffffff; border-collapse: collapse;">

                    {# Header #}
                    <tr>
                        <td style="background-color: #08111e; padding: 28px 32px;">
                            <table width="100%" cellpadding="0" cellspacing="0" border="0">
                                <tr>
                                    <td>
                                        <span style="font-family: Arial, sans-serif; font-size: 22px; font-weight: bold; color: #ffffff;">CF</span><span style="font-family: Arial, sans-serif; font-size: 22px; font-weight: bold; color: #00b4d8;">2m</span>
                                    </td>
                                    <td align="right">
                                        <span style="font-family: Arial, sans-serif; font-size: 12px; color: #7a95aa;">Nouvelle préinscription</span>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    {# Bandeau formation #}
                    <tr>
                        <td style="background-color: #e8f4fb; border-left: 4px solid #00b4d8; padding: 14px 32px;">
                            <span style="font-family: Arial, sans-serif; font-size: 13px; font-weight: bold; color: #1a2b3c;">Formation : {{ formation.title }}</span>
                        </td>
                    </tr>

                    {# Body #}
                    <tr>
                        <td style="padding: 32px;">

                            {# Nom #}
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px;">
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 11px; font-weight: bold; color: #7a95aa; padding-bottom: 4px;">NOM</td>
                                </tr>
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 15px; color: #1a2b3c;">{{ inscription.nom }}</td>
                                </tr>
                            </table>

                            {# Prénom #}
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px;">
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 11px; font-weight: bold; color: #7a95aa; padding-bottom: 4px;">PRÉNOM</td>
                                </tr>
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 15px; color: #1a2b3c;">{{ inscription.prenom }}</td>
                                </tr>
                            </table>

                            {# Email #}
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px;">
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 11px; font-weight: bold; color: #7a95aa; padding-bottom: 4px;">E-MAIL</td>
                                </tr>
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 15px;">
                                        <a href="mailto:{{ inscription.email }}" style="color: #00b4d8; text-decoration: none;">{{ inscription.email }}</a>
                                    </td>
                                </tr>
                            </table>

                            {# Téléphone #}
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px;">
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 11px; font-weight: bold; color: #7a95aa; padding-bottom: 4px;">TÉLÉPHONE</td>
                                </tr>
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 15px; color: #1a2b3c;">{{ inscription.telephone }}</td>
                                </tr>
                            </table>

                            {# Âge #}
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px;">
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 11px; font-weight: bold; color: #7a95aa; padding-bottom: 4px;">ÂGE</td>
                                </tr>
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 15px; color: #1a2b3c;">{{ inscription.age }} ans</td>
                                </tr>
                            </table>

                            {# Message #}
                            {% if inscription.message %}
                            <table width="100%" cellpadding="0" cellspacing="0" border="0">
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 11px; font-weight: bold; color: #7a95aa; padding-bottom: 8px;">MESSAGE</td>
                                </tr>
                                <tr>
                                    <td style="background-color: #f8fafc; border-left: 3px solid #00b4d8; padding: 16px 20px;">
                                        <span style="font-family: Arial, sans-serif; font-size: 14px; color: #1a2b3c; line-height: 1.7;">{{ inscription.message|nl2br }}</span>
                                    </td>
                                </tr>
                            </table>
                            {% endif %}

                        </td>
                    </tr>

                    {# CTA administration #}
                    <tr>
                        <td style="padding: 8px 32px 32px 32px;" align="center">
                            <a href="{{ adminListUrl }}"
                               style="display: inline-block; background-color: #00b4d8; color: #ffffff; font-family: Arial, sans-serif; font-size: 14px; font-weight: bold; text-decoration: none; padding: 12px 28px; border-radius: 4px;">
                                Gérer les préinscriptions
                            </a>
                        </td>
                    </tr>

                    {# Footer #}
                    <tr>
                        <td style="background-color: #f0f6fa; border-top: 1px solid #dde8f0; padding: 16px 32px;">
                            <span style="font-family: Arial, sans-serif; font-size: 12px; color: #7a95aa;">
                                Reçu le {{ inscription.createdAt|date('d/m/Y à H:i') }} &mdash; CF2m Centre de Formation
                            </span>
                        </td>
                    </tr>

                </table>

            </td>
        </tr>
    </table>

</body>
</html>
