<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" lang="fr">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Votre révision a été {{ approved ? 'approuvée' : 'rejetée' }} — CF2m</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f0f6fa;">

    {# Wrapper #}
    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f0f6fa;">
        <tr>
            <td align="center" style="padding: 32px 16px;">

                {# Card #}
                <table width="600" cellpadding="0" cellspacing="0" border="0"
                       style="background-color: #ffffff; border-collapse: collapse;">

                    {# Header #}
                    <tr>
                        <td style="background-color: #08111e; padding: 28px 32px;">
                            <table width="100%" cellpadding="0" cellspacing="0" border="0">
                                <tr>
                                    <td>
                                        <span style="font-family: Arial, sans-serif; font-size: 22px; font-weight: bold; color: #ffffff;">CF</span><span style="font-family: Arial, sans-serif; font-size: 22px; font-weight: bold; color: #00b4d8;">2m</span>
                                    </td>
                                    <td align="right">
                                        <span style="font-family: Arial, sans-serif; font-size: 12px; color: #7a95aa;">
                                            Révision {{ approved ? 'approuvée' : 'rejetée' }}
                                        </span>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    {# Bandeau statut #}
                    <tr>
                        <td style="background-color: {{ approved ? '#d1fae5' : '#fee2e2' }}; padding: 14px 32px;">
                            <span style="font-family: Arial, sans-serif; font-size: 14px; font-weight: bold; color: {{ approved ? '#065f46' : '#991b1b' }};">
                                {% if approved %}
                                    ✔ Votre modification a été approuvée et appliquée.
                                {% else %}
                                    ✖ Votre modification a été rejetée.
                                {% endif %}
                            </span>
                        </td>
                    </tr>

                    {# Body #}
                    <tr>
                        <td style="padding: 32px;">

                            {# Type d'entité #}
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px;">
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 11px; font-weight: bold; color: #7a95aa; padding-bottom: 4px;">
                                        TYPE
                                    </td>
                                </tr>
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 15px; color: #1a2b3c;">
                                        {{ revision.entityType|capitalize }}
                                    </td>
                                </tr>
                            </table>

                            {# Titre de l'entité #}
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px;">
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 11px; font-weight: bold; color: #7a95aa; padding-bottom: 4px;">
                                        ÉLÉMENT MODIFIÉ
                                    </td>
                                </tr>
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 15px; color: #1a2b3c;">
                                        {{ revision.entityTitle }}
                                    </td>
                                </tr>
                            </table>

                            {# Validé par #}
                            {% if revision.reviewedBy %}
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 20px;">
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 11px; font-weight: bold; color: #7a95aa; padding-bottom: 4px;">
                                        {{ approved ? 'APPROUVÉ PAR' : 'REJETÉ PAR' }}
                                    </td>
                                </tr>
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 15px; color: #1a2b3c;">
                                        {{ revision.reviewedBy.userName }}
                                    </td>
                                </tr>
                            </table>
                            {% endif %}

                            {# Note de révision #}
                            {% if revision.reviewNote %}
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 24px;">
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 11px; font-weight: bold; color: #7a95aa; padding-bottom: 8px;">
                                        COMMENTAIRE DE L'ADMINISTRATEUR
                                    </td>
                                </tr>
                                <tr>
                                    <td style="background-color: #f8fafc; border-left: 3px solid #00b4d8; padding: 16px 20px;">
                                        <span style="font-family: Arial, sans-serif; font-size: 14px; color: #1a2b3c; line-height: 1.7;">
                                            {{ revision.reviewNote }}
                                        </span>
                                    </td>
                                </tr>
                            </table>
                            {% endif %}

                        </td>
                    </tr>

                    {# Footer #}
                    <tr>
                        <td style="background-color: #f0f6fa; border-top: 1px solid #dde8f0; padding: 16px 32px;">
                            <span style="font-family: Arial, sans-serif; font-size: 12px; color: #7a95aa;">
                                Révision soumise le {{ revision.createdAt|date('d/m/Y à H:i') }}
                                {% if revision.reviewedAt %}
                                    &mdash; {{ approved ? 'Approuvée' : 'Rejetée' }} le {{ revision.reviewedAt|date('d/m/Y à H:i') }}
                                {% endif %}
                                &mdash; CF2m Centre de Formation
                            </span>
                        </td>
                    </tr>

                </table>
                {# /Card #}

            </td>
        </tr>
    </table>

</body>
</html>
