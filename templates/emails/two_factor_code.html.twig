<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" lang="fr">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Code de connexion — CF2m</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f0f6fa;">

    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f0f6fa;">
        <tr>
            <td align="center" style="padding: 32px 16px;">

                <table width="600" cellpadding="0" cellspacing="0" border="0"
                       style="background-color: #ffffff; border-collapse: collapse;">

                    {# Header #}
                    <tr>
                        <td style="background-color: #08111e; padding: 28px 32px;">
                            <table width="100%" cellpadding="0" cellspacing="0" border="0">
                                <tr>
                                    <td>
                                        <span style="font-family: Arial, sans-serif; font-size: 22px; font-weight: bold; color: #ffffff;">CF</span><span style="font-family: Arial, sans-serif; font-size: 22px; font-weight: bold; color: #00b4d8;">2m</span>
                                    </td>
                                    <td align="right">
                                        <span style="font-family: Arial, sans-serif; font-size: 12px; color: #7a95aa;">Double authentification</span>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    {# Body #}
                    <tr>
                        <td style="padding: 32px;">

                            {# Intro #}
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 24px;">
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 16px; font-weight: bold; color: #1a2b3c; padding-bottom: 8px;">
                                        Bonjour {{ user.userName }},
                                    </td>
                                </tr>
                                <tr>
                                    <td style="font-family: Arial, sans-serif; font-size: 14px; color: #4a5a6a; line-height: 1.6;">
                                        Une connexion à votre compte CF2m vient d'être initiée.
                                        Saisissez le code ci-dessous pour confirmer votre identité.
                                        Ce code est valable <strong>{{ ttl }} minutes</strong>.
                                    </td>
                                </tr>
                            </table>

                            {# Code #}
                            <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 24px;">
                                <tr>
                                    <td align="center">
                                        <div style="display: inline-block; background-color: #f0f6fa; border: 2px solid #00b4d8; border-radius: 8px; padding: 20px 40px;">
                                            <span style="font-family: 'Courier New', Courier, monospace; font-size: 36px; font-weight: bold; color: #08111e; letter-spacing: 12px;">{{ code }}</span>
                                        </div>
                                    </td>
                                </tr>
                            </table>

                            {# Avertissement #}
                            <table width="100%" cellpadding="0" cellspacing="0" border="0">
                                <tr>
                                    <td style="background-color: #fff8f0; border-left: 3px solid #e05c00; padding: 14px 18px;">
                                        <span style="font-family: Arial, sans-serif; font-size: 13px; color: #c04a00; line-height: 1.6;">
                                            Si vous n'êtes pas à l'origine de cette connexion, ignorez cet e-mail
                                            et changez immédiatement votre mot de passe.
                                        </span>
                                    </td>
                                </tr>
                            </table>

                        </td>
                    </tr>

                    {# Footer #}
                    <tr>
                        <td style="background-color: #f0f6fa; border-top: 1px solid #dde8f0; padding: 16px 32px;">
                            <span style="font-family: Arial, sans-serif; font-size: 12px; color: #7a95aa;">
                                Demande effectuée le {{ 'now'|date('d/m/Y à H:i') }} &mdash; CF2m Centre de Formation
                            </span>
                        </td>
                    </tr>

                </table>

            </td>
        </tr>
    </table>

</body>
</html>
