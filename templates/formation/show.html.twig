{% extends 'base.html.twig' %}

{% block title %}{{ formation.title }} — CF2m Centre de Formation{% endblock %}

{% block body_class %}page-formation-show{% endblock %}

{% block body %}

{% set formation_icons = {
    'aventure-digitale':                         'download-computer.svg',
    'animateur-multimedia':                       'movie-speaker.svg',
    'technicien-reseaux':                        'network-tree.svg',
    'digital-designer':                          'responsive-design.svg',
    'developpeur-web':                           'collect-computer.svg',
    'cheques-tic':                               'multimedia.svg',
    'illustration-num-rique-89768':              'design-ideas.svg',
    'marketing-digital-et-r-seaux-sociaux-59696':'network-globe.svg'
} %}

<section class="py-5">
    <div class="container">

        <nav aria-label="Fil d'ariane" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_home') }}">Accueil</a>
                </li>
                <li class="breadcrumb-item">
                    <a href="{{ path('app_home') }}#formations">Nos formations</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">
                    {{ formation.title }}
                </li>
            </ol>
        </nav>

        <div class="row justify-content-center">
            <div class="col-lg-8">

                <div class="card cf2m-card" style="{% if formation.colorPrimary %}--card-color-primary: {{ formation.colorPrimary }};{% endif %}{% if formation.colorSecondary %}--card-color-secondary: {{ formation.colorSecondary }};{% endif %}">
                    <div class="card-header d-flex justify-content-between align-items-center gap-3">
                        <h1 class="h3 mb-0">{{ formation.title }}</h1>
                        <div class="d-flex align-items-center gap-2 flex-shrink-0">
                            <span class="badge badge-status">Ouverte</span>
                            {% if formation_icons[formation.slug] is defined %}
                                <img src="{{ asset('images/formation-icons/' ~ formation_icons[formation.slug]) }}"
                                     alt=""
                                     aria-hidden="true"
                                     class="cf2m-formation-icon"
                                     width="56" height="56">
                            {% endif %}
                        </div>
                    </div>

                    <div class="card-body">
                        {% if formation.publishedAt %}
                            <p class="mb-3">
                                <small class="cf2m-muted-label">
                                    Publiée le {{ formation.publishedAt|date('d/m/Y') }}
                                </small>
                            </p>
                        {% endif %}

                        {% if formation.description %}
                            <div class="cf2m-formation-description">
                                {{ formation.description|raw }}
                            </div>
                        {% else %}
                            <p class="text-muted fst-italic">Aucune description disponible.</p>
                        {% endif %}
                    </div>

                    {% if works is not empty %}
                        <div class="card-body border-top pt-3">
                            <h2 class="h5 mb-3">Travaux réalisés</h2>
                            <ul class="list-unstyled mb-0">
                                {% for work in works %}
                                    <li class="mb-2">
                                        <a href="{{ path('app_works_show', {formationSlug: formation.slug, slug: work.slug}) }}" class="cf2m-works-link">
                                            <span class="cf2m-dropdown-arrow">›</span>
                                            {{ work.title }}
                                        </a>
                                        {% if work.publishedAt %}
                                            <small class="text-muted ms-2">
                                                — {{ work.publishedAt|date('d/m/Y') }}
                                            </small>
                                        {% endif %}
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}

                    <div class="card-footer bg-transparent border-0 pb-3 d-flex gap-2">
                        <a href="{{ path('app_home') }}#formations" class="btn btn-outline-secondary btn-sm">
                            ← Retour aux formations
                        </a>
                        <a href="#" class="btn btn-primary btn-sm">
                            S'inscrire
                        </a>
                    </div>
                </div>

            </div>
        </div>

    </div>
</section>

{% endblock %}
