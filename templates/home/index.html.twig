{% extends 'base.html.twig' %}

{% block title %}Accueil — CF2m Centre de Formation{% endblock %}

{% block body_class %}page-home{% endblock %}

{% block body %}

{# ── Section Hero ──────────────────────────────────────────────────── #}
<section class="cf2m-hero">
    <div class="container">
        <div class="row align-items-center g-4">

            {# ── Colonne gauche : contenu glassmorphisme ── #}
            <div class="col-lg-6 col-md-9">
                <div class="cf2m-hero-glass">

                    <p class="cf2m-hero-label">Formations Professionnelles</p>

                    <h1 class="mb-4">
                        des métiers<br>
                        <em>du numérique</em>
                    </h1>

                    <p class="lead mb-4">
                        Développez vos compétences avec nos formations professionnelles
                        adaptées aux besoins du marché belge. Étudiants, demandeurs d'emploi,
                        entreprises — nous vous accompagnons.
                    </p>

                    {# Stats #}
                    <div class="cf2m-hero-stats">
                        <div>
                            <div class="cf2m-stat-value">100%</div>
                            <div class="cf2m-stat-label">gratuit</div>
                        </div>
                        <div>
                            <div class="cf2m-stat-value">80%</div>
                            <div class="cf2m-stat-label">de pratique</div>
                        </div>
                        <div>
                            <div class="cf2m-stat-value">1600 h</div>
                            <div class="cf2m-stat-label">de cours</div>
                        </div>
                    </div>

                    <a href="#formations" class="cf2m-hero-btn">
                        Nos formations
                    </a>

                </div>
            </div>

            {# ── Colonne droite : portrait circulaire ── #}
            <div class="col-lg-6 d-none d-lg-flex cf2m-hero-portrait-wrap">
                <div class="cf2m-hero-portrait-outer">
                    <img class="cf2m-hero-portrait-ring"
                         src="{{ asset('images/cercle-contour-blanc.svg') }}"
                         alt="" aria-hidden="true">
                    <div class="cf2m-hero-portrait">
                        {#
                            Déposer une photo de formateur/trice à :
                            public/images/hero-portrait.jpg
                            (format portrait, cadrage visage + buste)
                        #}
                        <img src="{{ asset('images/hero-portrait.jpg') }}"
                             alt="Étudiante CF2m"
                             width="340" height="340"
                             style="object-position: 80% center;">
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

{# ── Section Formations ────────────────────────────────────────────── #}
<section id="formations" class="cf2m-partners py-5">
    <div class="container">
        <p class="cf2m-section-label text-center">Catalogue</p>
        <h2 class="cf2m-section-title text-center">Nos formations</h2>

        {% if formations is empty %}
            <div class="text-center text-muted py-5">
                <p class="fs-5">Aucune formation disponible pour le moment.</p>
                <p>Revenez bientôt pour découvrir notre catalogue.</p>
            </div>
        {% else %}
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                {% for formation in formations %}
                    <div class="col">
                        <div class="card cf2m-card" style="{% if formation.colorPrimary %}--card-color-primary: {{ formation.colorPrimary }};{% endif %}{% if formation.colorSecondary %}--card-color-secondary: {{ formation.colorSecondary }};{% endif %}">
                            <div class="card-header d-flex justify-content-between align-items-start">
                                <span>{{ formation.title }}</span>
                                <span class="badge badge-status ms-2 flex-shrink-0">Ouverte</span>
                            </div>
                            <div class="card-body">
                                {% if formation.description %}
                                    <p class="card-text">
                                        {{ formation.description|striptags|slice(0, 150) }}{% if formation.description|length > 150 %}…{% endif %}
                                    </p>
                                {% endif %}
                                {% if formation.publishedAt %}
                                    <p class="card-text mt-2">
                                        <small style="color: #7a95aa;">
                                            Publiée le {{ formation.publishedAt|date('d/m/Y') }}
                                        </small>
                                    </p>
                                {% endif %}
                            </div>
                            <div class="card-footer border-0 pb-3">
                                <a href="{{ path('app_formation_show', {slug: formation.slug}) }}"
                                   class="btn btn-outline-secondary btn-sm w-100"
                                   aria-label="Voir la formation {{ formation.title }}">
                                    En savoir plus
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>

{# ── Section Partenaires ───────────────────────────────────────────── #}
{% if partenaires is not empty %}
<section id="partenaires" class="cf2m-partners py-5">
    <div class="container">
        <p class="cf2m-section-label text-center">Ils nous font confiance</p>
        <h2 class="cf2m-section-title text-center">Nos partenaires</h2>

        <div class="d-flex flex-wrap justify-content-center gap-3 mt-4">
            {% for partenaire in partenaires %}
                {% if partenaire.url %}
                    <a href="{{ partenaire.url }}" target="_blank" rel="noopener noreferrer"
                       class="cf2m-partner-item"
                       title="{{ partenaire.description ?? partenaire.nom }}">
                        {{ partenaire.nom }}
                    </a>
                {% else %}
                    <span class="cf2m-partner-item">{{ partenaire.nom }}</span>
                {% endif %}
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{% endblock %}
