{% extends 'base.html.twig' %}

{% block title %}Accueil — CF2m Centre de Formation{% endblock %}
{% block meta_description %}<meta name="description" content="Le CF2m, Centre de Formation 2M, propose des formations professionnelles certifiantes en informatique, multimédia et digital pour les demandeurs d'emploi en Belgique.">{% endblock %}

{% block body_class %}page-home{% endblock %}

{% block body %}

{# ── Section Hero ──────────────────────────────────────────────────── #}
<section class="cf2m-hero">
    <div class="container">
        <div class="row align-items-center g-4">

            {# ── Colonne gauche : contenu glassmorphisme ── #}
            <div class="col-lg-6 col-md-9">
                <div class="cf2m-hero-glass">

                    <p class="cf2m-hero-label">Formations Professionnelles</p>

                    <h1 class="mb-4">
                        des métiers<br>
                        <em>du numérique</em>
                    </h1>

                    <p class="lead mb-4">
                        Développez vos compétences avec nos formations professionnelles
                        adaptées aux besoins du marché belge. Étudiants, demandeurs d'emploi,
                        entreprises — nous vous accompagnons.
                    </p>

                    {# Stats #}
                    <div class="cf2m-hero-stats">
                        <div>
                            <div class="cf2m-stat-value">100%</div>
                            <div class="cf2m-stat-label">gratuit</div>
                        </div>
                        <div>
                            <div class="cf2m-stat-value">80%</div>
                            <div class="cf2m-stat-label">de pratique</div>
                        </div>
                        <div>
                            <div class="cf2m-stat-value">1600 h</div>
                            <div class="cf2m-stat-label">de cours</div>
                        </div>
                    </div>

                    <a href="#formations" class="cf2m-hero-btn">
                        Nos formations
                    </a>

                </div>
            </div>

            {# ── Colonne droite : portrait circulaire ── #}
            <div class="col-lg-6 d-none d-lg-flex cf2m-hero-portrait-wrap">
                <div class="cf2m-hero-portrait-outer">
                    <img class="cf2m-hero-portrait-ring"
                         src="{{ asset('images/cercle-contour-blanc.svg') }}"
                         alt="" aria-hidden="true">
                    <div class="cf2m-hero-portrait">
                        {#
                            Déposer une photo de formateur/trice à :
                            public/images/hero-portrait.jpg + hero-portrait.webp
                            (format portrait, cadrage visage + buste)
                        #}
                        <picture>
                            <source srcset="{{ asset('images/hero-portrait.webp') }}" type="image/webp">
                            <img src="{{ asset('images/hero-portrait.jpg') }}"
                                 alt="Étudiante CF2m"
                                 width="340" height="340"
                                 style="object-position: 80% center;"
                                 fetchpriority="high">
                        </picture>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

{# ── Section Formations ────────────────────────────────────────────── #}
<section id="formations" class="py-5">
    <div class="container">
        <p class="cf2m-section-label text-center">Catalogue</p>
        <h2 class="cf2m-section-title text-center">Nos formations</h2>

        {% if formations is empty %}
            <div class="text-center text-muted py-5">
                <p class="fs-5">Aucune formation disponible pour le moment.</p>
                <p>Revenez bientôt pour découvrir notre catalogue.</p>
            </div>
        {% else %}
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                {% set formation_icons = {
                    'aventure-digitale':                    'download-computer.svg',
                    'animateur-multimedia':                  'movie-speaker.svg',
                    'technicien-reseaux':                   'network-tree.svg',
                    'digital-designer':                     'responsive-design.svg',
                    'developpeur-web':                      'collect-computer.svg',
                    'cheques-tic':                          'multimedia.svg',
                    'illustration-num-rique-89768':          'design-ideas.svg',
                    'marketing-digital-et-r-seaux-sociaux-59696': 'network-globe.svg'
                } %}
                {% for formation in formations %}
                    <div class="col">
                        <div class="card cf2m-card{% if formation.status == 'recruiting' %} cf2m-card--recruiting{% endif %}" style="{% if formation.colorPrimary %}--card-color-primary: {{ formation.colorPrimary }};{% endif %}{% if formation.colorSecondary %}--card-color-secondary: {{ formation.colorSecondary }};{% endif %}">
                            <div class="card-header d-flex justify-content-between align-items-start gap-2">
                                <div>
                                    <span>{{ formation.title }}</span>
                                    {% if formation.status == 'recruiting' %}
                                        <span class="badge bg-warning text-dark d-block mt-1" style="font-size: .7rem; width: fit-content;">Recrutement en cours</span>
                                    {% endif %}
                                </div>
                                {% if formation_icons[formation.slug] is defined %}
                                    <img src="{{ asset('images/formation-icons/' ~ formation_icons[formation.slug]) }}"
                                         alt=""
                                         aria-hidden="true"
                                         class="cf2m-formation-icon flex-shrink-0"
                                         width="32" height="32"
                                         loading="lazy">
                                {% endif %}
                            </div>
                            <div class="card-body">
                                {% if formation.descriptionCourte %}
                                    <p class="card-text">{{ formation.descriptionCourte }}</p>
                                {% elseif formation.description %}
                                    {% set desc = formation.description|plain_text %}
                                    <p class="card-text">
                                        {{ desc|slice(0, 150) }}{% if desc|length > 150 %}…{% endif %}
                                    </p>
                                {% endif %}
                            </div>
                            <div class="card-footer border-0 pb-3">
                                <a href="{{ path('app_formation_show', {slug: formation.slug}) }}"
                                   class="btn {% if formation.status == 'recruiting' %}btn-warning{% else %}btn-outline-secondary{% endif %} btn-sm w-100"
                                   aria-label="Voir la formation {{ formation.title }}">
                                    {% if formation.status == 'recruiting' %}S'inscrire{% else %}En savoir plus{% endif %}
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>

{# ── Section Partenaires ───────────────────────────────────────────── #}
{% if partenaires is not empty %}
<section id="partenaires" class="cf2m-partners py-5">
    <div class="container">
        <p class="cf2m-section-label text-center">Ils nous font confiance</p>
        <h2 class="cf2m-section-title text-center">Nos partenaires</h2>

        <div class="d-flex flex-wrap justify-content-center align-items-center gap-4 mt-4">
            {% for partenaire in partenaires %}
                {% set contenu %}
                    {% if partenaire.logo %}
                        <img src="{{ asset('uploads/partenaire-logos/' ~ partenaire.logo) }}"
                             alt="{{ partenaire.nom }}"
                             class="cf2m-partner-logo"
                             loading="lazy">
                    {% else %}
                        {{ partenaire.nom }}
                    {% endif %}
                {% endset %}
                {% if partenaire.url %}
                    <a href="{{ partenaire.url }}" target="_blank" rel="noopener noreferrer"
                       class="cf2m-partner-item"
                       title="{{ partenaire.description ?? partenaire.nom }}">
                        {{ contenu }}
                    </a>
                {% else %}
                    <span class="cf2m-partner-item">{{ contenu }}</span>
                {% endif %}
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{% endblock %}
