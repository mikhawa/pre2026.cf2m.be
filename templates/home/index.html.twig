{% extends 'base.html.twig' %}

{% block title %}Accueil — CF2m Centre de Formation{% endblock %}

{% block body_class %}page-home{% endblock %}

{% block body %}

{# ── Section Hero ──────────────────────────────────────────────────── #}
<section class="cf2m-hero">
    <div class="container">
        <div class="row align-items-center g-4">

            {# ── Colonne gauche : contenu glassmorphisme ── #}
            <div class="col-lg-6 col-md-9">
                <div class="cf2m-hero-glass">

                    <p class="cf2m-hero-label">Formations Professionnelles</p>

                    <h1 class="mb-4">
                        des métiers<br>
                        <em>du numérique</em>
                    </h1>

                    <p class="lead mb-4">
                        Développez vos compétences avec nos formations professionnelles
                        adaptées aux besoins du marché belge. Étudiants, demandeurs d'emploi,
                        entreprises — nous vous accompagnons.
                    </p>

                    {# Stats #}
                    <div class="cf2m-hero-stats">
                        <div>
                            <div class="cf2m-stat-value">100%</div>
                            <div class="cf2m-stat-label">gratuit</div>
                        </div>
                        <div>
                            <div class="cf2m-stat-value">80%</div>
                            <div class="cf2m-stat-label">de pratique</div>
                        </div>
                        <div>
                            <div class="cf2m-stat-value">1600 h</div>
                            <div class="cf2m-stat-label">de cours</div>
                        </div>
                    </div>

                    <a href="#formations" class="cf2m-hero-btn">
                        Nos formations
                    </a>

                </div>
            </div>

            {# ── Colonne droite : collage photos ── #}
            <div class="col-lg-6 d-none d-lg-block">
                <div class="cf2m-hero-collage">
                    <div class="cf2m-hero-collage-card cf2m-hero-collage-card--tl">
                        <img src="{{ asset('images/hero-portrait.jpg') }}"
                             alt="Étudiants CF2m en cours"
                             style="object-position: 20% center;">
                    </div>
                    <div class="cf2m-hero-collage-card cf2m-hero-collage-card--main">
                        <img src="{{ asset('images/hero-portrait.jpg') }}"
                             alt="Formation numérique CF2m"
                             style="object-position: 80% center;">
                    </div>
                    <div class="cf2m-hero-collage-card cf2m-hero-collage-card--bl">
                        <img src="{{ asset('images/hero-portrait.jpg') }}"
                             alt="Atelier pratique CF2m"
                             style="object-position: 50% 30%;">
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

{# ── Section Formations ────────────────────────────────────────────── #}
<section id="formations" class="py-5" style="background-image: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), linear-gradient(to bottom, #827e7e 0%, rgba(130,126,126,0.5) 50%, rgba(130,126,126,0.5) 100%), url('{{ asset('images/formations-bg.jpg') }}'); background-size: cover; background-position: center; border-top: 5px solid #38476b;">
    <div class="container">
        <p class="cf2m-section-label text-center">Catalogue</p>
        <h2 class="cf2m-section-title text-center">Nos formations</h2>

        {% if formations is empty %}
            <div class="text-center text-muted py-5">
                <p class="fs-5">Aucune formation disponible pour le moment.</p>
                <p>Revenez bientôt pour découvrir notre catalogue.</p>
            </div>
        {% else %}
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                {% set formation_icons = {
                    'aventure-digitale':                    'download-computer.svg',
                    'animateur-multimedia':                  'movie-speaker.svg',
                    'technicien-reseaux':                   'network-tree.svg',
                    'digital-designer':                     'responsive-design.svg',
                    'developpeur-web':                      'collect-computer.svg',
                    'cheques-tic':                          'multimedia.svg',
                    'illustration-num-rique-89768':          'design-ideas.svg',
                    'marketing-digital-et-r-seaux-sociaux-59696': 'network-globe.svg'
                } %}
                {% for formation in formations %}
                    <div class="col">
                        <div class="card cf2m-card{% if formation.status == 'recruiting' %} cf2m-card--recruiting{% endif %}" style="{% if formation.colorPrimary %}--card-color-primary: {{ formation.colorPrimary }};{% endif %}{% if formation.colorSecondary %}--card-color-secondary: {{ formation.colorSecondary }};{% endif %}">
                            <div class="card-header d-flex justify-content-between align-items-start gap-2">
                                <div>
                                    <span>{{ formation.title }}</span>
                                    {% if formation.status == 'recruiting' %}
                                        <span class="badge bg-warning text-dark d-block mt-1" style="font-size: .7rem; width: fit-content;">Recrutement en cours</span>
                                    {% endif %}
                                </div>
                                {% if formation_icons[formation.slug] is defined %}
                                    <img src="{{ asset('images/formation-icons/' ~ formation_icons[formation.slug]) }}"
                                         alt=""
                                         aria-hidden="true"
                                         class="cf2m-formation-icon flex-shrink-0"
                                         width="32" height="32">
                                {% endif %}
                            </div>
                            <div class="card-body">
                                {% if formation.descriptionCourte %}
                                    <p class="card-text">{{ formation.descriptionCourte }}</p>
                                {% elseif formation.description %}
                                    {% set desc = formation.description|plain_text %}
                                    <p class="card-text">
                                        {{ desc|slice(0, 150) }}{% if desc|length > 150 %}…{% endif %}
                                    </p>
                                {% endif %}
                            </div>
                            <div class="card-footer border-0 pb-3">
                                <a href="{{ path('app_formation_show', {slug: formation.slug}) }}"
                                   class="btn {% if formation.status == 'recruiting' %}btn-warning{% else %}btn-outline-secondary{% endif %} btn-sm w-100"
                                   aria-label="Voir la formation {{ formation.title }}">
                                    {% if formation.status == 'recruiting' %}S'inscrire{% else %}En savoir plus{% endif %}
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>

{# ── Section Partenaires ───────────────────────────────────────────── #}
{% if partenaires is not empty %}
<section id="partenaires" class="cf2m-partners py-5">
    <div class="container">
        <p class="cf2m-section-label text-center">Ils nous font confiance</p>
        <h2 class="cf2m-section-title text-center">Nos partenaires</h2>

        <div class="d-flex flex-wrap justify-content-center gap-3 mt-4">
            {% for partenaire in partenaires %}
                {% if partenaire.url %}
                    <a href="{{ partenaire.url }}" target="_blank" rel="noopener noreferrer"
                       class="cf2m-partner-item"
                       title="{{ partenaire.description ?? partenaire.nom }}">
                        {{ partenaire.nom }}
                    </a>
                {% else %}
                    <span class="cf2m-partner-item">{{ partenaire.nom }}</span>
                {% endif %}
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# ── Section Maîtrisez les outils ─────────────────────────────────── #}
<section class="cf2m-tools-section">
    <div class="container text-center">
        <p class="cf2m-section-label">Compétences</p>
        <h2 class="cf2m-tools-section-title">
            Maîtrisez les outils <em>d'aujourd'hui</em>
        </h2>
        <p class="cf2m-tools-subtitle">
            Nos formations vous préparent à utiliser les technologies les plus demandées par les entreprises belges.
        </p>

        <div class="cf2m-tools-grid">
            {% set outils = [
                {nom: 'HTML5',        icon: '🌐'},
                {nom: 'CSS3',         icon: '🎨'},
                {nom: 'JavaScript',   icon: '⚡'},
                {nom: 'PHP',          icon: '🐘'},
                {nom: 'MySQL',        icon: '🗄️'},
                {nom: 'WordPress',    icon: '📝'},
                {nom: 'Bootstrap',    icon: '📐'},
                {nom: 'Figma',        icon: '✏️'},
                {nom: 'Adobe Suite',  icon: '🖌️'},
                {nom: 'Réseaux',      icon: '🔗'},
                {nom: 'Linux',        icon: '🐧'},
                {nom: 'Git',          icon: '🔀'},
            ] %}
            {% for outil in outils %}
                <span class="cf2m-tool-badge">
                    <span aria-hidden="true">{{ outil.icon }}</span>
                    {{ outil.nom }}
                </span>
            {% endfor %}
        </div>
    </div>
</section>

{# ── Section Pourquoi choisir CF2M ────────────────────────────────── #}
<section class="cf2m-why-section">
    <div class="container">
        <div class="row align-items-center g-5">

            <div class="col-lg-5">
                <p class="cf2m-why-label">Nos atouts</p>
                <h2 class="cf2m-why-title">
                    Pourquoi choisir<br><em>le CF2M ?</em>
                </h2>

                <div class="cf2m-why-stats">
                    <div class="cf2m-why-stat-item">
                        <div class="cf2m-why-stat-value">85%</div>
                        <div class="cf2m-why-stat-label">Taux d'emploi</div>
                    </div>
                    <div class="cf2m-why-stat-item">
                        <div class="cf2m-why-stat-value">100%</div>
                        <div class="cf2m-why-stat-label">Gratuit</div>
                    </div>
                    <div class="cf2m-why-stat-item">
                        <div class="cf2m-why-stat-value">80%</div>
                        <div class="cf2m-why-stat-label">Pratique</div>
                    </div>
                    <div class="cf2m-why-stat-item">
                        <div class="cf2m-why-stat-value">1600h</div>
                        <div class="cf2m-why-stat-label">De formation</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="cf2m-testimonial">
                    <img src="{{ asset('images/hero-portrait.jpg') }}"
                         alt="Témoignage étudiant CF2m"
                         class="cf2m-testimonial-img">
                    <div>
                        <p class="cf2m-testimonial-quote">
                            « J'avais arrêté l'école à 16 ans. Je pensais que le numérique,
                            ce n'était pas pour moi. Grâce au CF2M, j'ai trouvé ma voie et
                            aujourd'hui je travaille avec passion. »
                        </p>
                        <p class="cf2m-testimonial-author">
                            Louis, 20 ans — Développeur Front-End
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

{# ── Section Entreprises & Recruteurs ─────────────────────────────── #}
<section class="cf2m-cta-section">
    <div class="container">
        <h2 class="cf2m-cta-title">
            Entreprises &amp; <em>Recruteurs</em>
        </h2>
        <p class="cf2m-cta-text">
            Vous cherchez des talents formés aux métiers du numérique ?
            Nos diplômés sont opérationnels dès leur sortie de formation.
            Contactez-nous pour accéder à notre vivier de candidats.
        </p>
        <a href="{{ path('app_contact') }}" class="cf2m-cta-btn">
            Nous contacter
        </a>
    </div>
</section>

{% endblock %}
