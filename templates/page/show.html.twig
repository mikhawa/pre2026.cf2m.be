{% extends 'base.html.twig' %}

{% block title %}{{ page.title }} — CF2m Centre de Formation{% endblock %}

{% block body_class %}page-activite-show{% endblock %}

{% block body %}

<section class="py-5">
    <div class="container">

        <nav aria-label="Fil d'ariane" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_home') }}">Accueil</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">
                    {{ page.title }}
                </li>
            </ol>
        </nav>

        <div class="row justify-content-center">
            <div class="col-lg-8">

                <div class="card cf2m-card">
                    <div class="card-header">
                        <h1 class="h3 mb-0">{{ page.title }}</h1>
                    </div>

                    <div class="card-body">
                        {% if page.publishedAt %}
                            <p class="mb-3">
                                <small style="color: #7a95aa;">
                                    Publiée le {{ page.publishedAt|date('d/m/Y') }}
                                </small>
                            </p>
                        {% endif %}

                        {% if page.content %}
                            <div class="cf2m-page-content">
                                {{ page.content|raw }}
                            </div>
                        {% else %}
                            <p class="text-muted fst-italic">Aucun contenu disponible.</p>
                        {% endif %}
                    </div>

                    <div class="card-footer bg-transparent border-0 pb-3">
                        <a href="{{ path('app_home') }}" class="btn btn-outline-secondary btn-sm">
                            ← Retour à l'accueil
                        </a>
                    </div>
                </div>

            </div>
        </div>

    </div>
</section>

{% endblock %}
