{% extends 'base.html.twig' %}

{% block title %}Modifier mon profil — CF2m{% endblock %}

{% block body_class %}page-profil{% endblock %}

{% block body %}

<section class="py-5">
    <div class="container">

        <div class="row justify-content-center">
            <div class="col-lg-8" data-controller="avatar-crop">

                <div class="card cf2m-card mb-0">
                    <div class="card-header d-flex justify-content-between align-items-center gap-2">
                        <h1 class="h3 mb-0">Modifier mon profil</h1>
                        <a href="{{ path('app_profile') }}"
                           class="btn btn-outline-secondary btn-sm">
                            ← Mon profil
                        </a>
                    </div>
                    <div class="card-body p-4">

                        {{ form_start(form, {attr: {
                            novalidate: 'novalidate',
                            enctype: 'multipart/form-data',
                            class: 'cf2m-profile-form'
                        }}) }}

                            {# Avatar #}
                            <div class="mb-4">
                                <label class="cf2m-form-label">{{ form_label(form.avatarFile) }}</label>
                                <div class="cf2m-avatar-upload d-flex align-items-center gap-3">
                                    <div class="cf2m-avatar-wrap flex-shrink-0">
                                        {% if user.avatarName %}
                                            <img src="{{ asset('uploads/avatars/' ~ user.avatarName) }}"
                                                 alt="" class="cf2m-avatar-img"
                                                 data-avatar-crop-target="preview">
                                        {% else %}
                                            <div class="cf2m-avatar-placeholder"
                                                 data-avatar-crop-target="previewPlaceholder">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                                     fill="none" stroke="currentColor" stroke-width="1.2"
                                                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                                    <circle cx="12" cy="8" r="4"/>
                                                    <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                                                </svg>
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div class="flex-grow-1">
                                        {{ form_widget(form.avatarFile, {attr: {
                                            class: 'form-control cf2m-input cf2m-file-input',
                                            id: 'avatar-file-input',
                                            'data-avatar-crop-target': 'fileInput',
                                            'data-action': 'change->avatar-crop#fileChanged'
                                        }}) }}
                                        {{ form_errors(form.avatarFile) }}
                                        <small class="text-muted d-block mt-1">JPEG, PNG ou WebP — 10 Mo max.</small>
                                    </div>
                                </div>
                            </div>

                            {# Biographie #}
                            <div class="mb-4">
                                {{ form_label(form.biography, null, {label_attr: {class: 'cf2m-form-label'}}) }}
                                {{ form_widget(form.biography, {attr: {class: 'form-control cf2m-input'}}) }}
                                {{ form_errors(form.biography) }}
                                <small class="text-muted">600 caractères maximum.</small>
                            </div>

                            {# Liens #}
                            <div class="mb-4">
                                <p class="cf2m-form-label mb-2">Liens externes <small class="text-muted fw-normal">(3 maximum)</small></p>
                                <div class="d-flex flex-column gap-2">
                                    {{ form_widget(form.externalLink1, {attr: {class: 'form-control cf2m-input'}}) }}
                                    {{ form_errors(form.externalLink1) }}
                                    {{ form_widget(form.externalLink2, {attr: {class: 'form-control cf2m-input'}}) }}
                                    {{ form_errors(form.externalLink2) }}
                                    {{ form_widget(form.externalLink3, {attr: {class: 'form-control cf2m-input'}}) }}
                                    {{ form_errors(form.externalLink3) }}
                                </div>
                            </div>

                            <button type="submit" class="btn cf2m-btn-submit w-100">
                                Enregistrer les modifications
                            </button>

                        {{ form_end(form) }}

                    </div>
                </div>

                {# ── Modal de recadrage avatar ─────────────────────────────── #}
                <div class="modal fade" id="avatar-crop-modal" tabindex="-1"
                     aria-labelledby="avatar-crop-modal-label" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content cf2m-crop-modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title" id="avatar-crop-modal-label">Recadrer la photo de profil</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                            </div>
                            <div class="modal-body p-0 cf2m-crop-container">
                                <cropper-canvas background style="width: 100%; height: 100%;">
                                    <cropper-image data-avatar-crop-target="cropperImage"
                                                   rotatable scalable translatable></cropper-image>
                                    <cropper-shade hidden></cropper-shade>
                                    <cropper-handle action="select" plain></cropper-handle>
                                    <cropper-selection data-avatar-crop-target="cropperSelection"
                                                       aspect-ratio="1"
                                                       initial-coverage="0.8"
                                                       movable resizable>
                                        <cropper-grid role="grid" covered></cropper-grid>
                                        <cropper-crosshair centered></cropper-crosshair>
                                        <cropper-handle action="move" theme-color="rgba(255,255,255,0.35)"></cropper-handle>
                                        <cropper-handle action="n-resize"></cropper-handle>
                                        <cropper-handle action="e-resize"></cropper-handle>
                                        <cropper-handle action="s-resize"></cropper-handle>
                                        <cropper-handle action="w-resize"></cropper-handle>
                                        <cropper-handle action="ne-resize"></cropper-handle>
                                        <cropper-handle action="nw-resize"></cropper-handle>
                                        <cropper-handle action="se-resize"></cropper-handle>
                                        <cropper-handle action="sw-resize"></cropper-handle>
                                    </cropper-selection>
                                </cropper-canvas>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-outline-secondary"
                                        data-bs-dismiss="modal">Annuler</button>
                                <button type="button" class="btn cf2m-btn-submit"
                                        data-action="click->avatar-crop#confirm">
                                    Valider le recadrage
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>
</section>

{% endblock %}
