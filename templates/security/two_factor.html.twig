{% extends 'base.html.twig' %}

{% block title %}Double authentification — CF2m Centre de Formation{% endblock %}

{% block body_class %}page-login{% endblock %}

{% block body %}

<section class="cf2m-login-section">

    {# Blobs décoratifs en arrière-plan #}
    <div class="cf2m-login-blob cf2m-login-blob--tl" aria-hidden="true"></div>
    <div class="cf2m-login-blob cf2m-login-blob--br" aria-hidden="true"></div>

    <div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh; padding-top: 70px;">
        <div class="cf2m-login-card">

            {# En-tête #}
            <div class="cf2m-login-header">
                <img src="{{ asset('images/logo-cf2m.svg') }}"
                     alt="Logo CF2m"
                     width="108" height="108"
                     class="cf2m-login-logo cf2m-login-logo--dark">
                <img src="{{ asset('images/logo-cf2m-bleu.svg') }}"
                     alt="Logo CF2m"
                     width="108" height="108"
                     class="cf2m-login-logo cf2m-login-logo--light">
                <h1 class="cf2m-login-title">Double authentification</h1>
                <p class="cf2m-login-subtitle">Un code a été envoyé à <strong>{{ email }}</strong></p>
            </div>

            {# Flash messages #}
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                </div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="cf2m-login-error" role="alert">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2.5"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    {{ message }}
                </div>
            {% endfor %}

            {# Code expiré #}
            {% if expired %}
                <div class="cf2m-login-error" role="alert">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2.5"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    Votre code a expiré. Veuillez en demander un nouveau.
                </div>
            {% endif %}

            {# Erreur de saisie #}
            {% if error %}
                <div class="cf2m-login-error" role="alert">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2.5"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                    {{ error }}
                </div>
            {% endif %}

            {# Formulaire de saisie du code #}
            <form method="post" action="{{ path('app_two_factor') }}" novalidate data-turbo="false">

                <div class="cf2m-login-field">
                    <label for="inputCode" class="cf2m-login-label">Code de vérification</label>
                    <div class="cf2m-login-input-wrap">
                        <svg class="cf2m-login-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                        <input type="text"
                               id="inputCode"
                               name="code"
                               class="cf2m-login-input"
                               placeholder="000000"
                               maxlength="6"
                               pattern="[0-9]{6}"
                               inputmode="numeric"
                               autocomplete="one-time-code"
                               autofocus
                               required>
                    </div>
                    <small class="text-muted mt-1 d-block">Saisissez le code à 6 chiffres reçu par email. Valable 15 minutes.</small>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('two_factor') }}">

                <button type="submit" class="cf2m-login-btn">
                    Valider le code
                </button>

            </form>

            {# Renvoyer le code #}
            <form method="post" action="{{ path('app_two_factor_resend') }}" class="mt-3" data-turbo="false">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('two_factor_resend') }}">
                <button type="submit" class="btn btn-link p-0 text-decoration-none"
                        style="font-size: 0.875rem; color: var(--cf2m-accent, #00b4d8);">
                    Je n'ai pas reçu le code &mdash; Renvoyer
                </button>
            </form>

            {# Pied de carte #}
            <p class="cf2m-login-back">
                <a href="{{ path('app_logout') }}">← Se déconnecter</a>
            </p>

        </div>
    </div>

</section>

{% endblock %}
